# ════════════════════════════════════════════════════════════════
# CollabBoard Environment Configuration
# ════════════════════════════════════════════════════════════════

# ── Server Environment ────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Database ──────────────────────────────────────────────────────
# MongoDB Atlas Connection String
# Get this from: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster0.abcdef.mongodb.net/collabboard?retryWrites=true&w=majority

# ── JWT Secrets (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
# Keep these SECRET and never commit them!
JWT_ACCESS_SECRET=your_super_secret_access_token_key_here_change_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_token_key_here_change_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Client Configuration ──────────────────────────────────────────
# The CLIENT_URL must match your frontend deployment URL exactly
# For development: http://localhost:5173 (Vite default)
# For Railway: https://your-app-name.railway.app (match your Vercel deployment)
CLIENT_URL=http://localhost:5173

# ── Optional: Server URL for Production Environments ────────────
# Only needed if your client needs to connect to a different domain
# Usually leave this empty and let the client auto-detect
VITE_SERVER_URL=

# ════════════════════════════════════════════════════════════════
# IMPORTANT DEPLOYMENT NOTES:
# ════════════════════════════════════════════════════════════════
# 1. MongoDB Atlas:
#    - Create a free cluster at: https://www.mongodb.com/cloud/atlas
#    - Add a database user and get connection string
#    - Add your Railway/Vercel IPs to Network Access whitelist
#    - Or use 0.0.0.0/0 for development (not recommended for production)
#
# 2. JWT Secrets:
#    Generate secure random strings and set them in Railway/Vercel secrets
#    Never use the example values in production!
#
# 3. CLIENT_URL MUST MATCH:
#    Railway server CORS must allow your Vercel/client frontend URL
#    If you see CORS errors, this is the first thing to check
#
# 4. Refresh Cookie:
#    HttpOnly refresh cookies are sent at path: '/'
#    Verify CORS credentials:true is set in both client and server
#    Check DevTools → Application → Cookies for 'refreshToken' cookie
# ════════════════════════════════════════════════════════════════
