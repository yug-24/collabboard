# ════════════════════════════════════════════════════════════════
# CollabBoard Client Environment Configuration
# ════════════════════════════════════════════════════════════════

# ── Development Environment ───────────────────────────────────────
# These are used by Vite and browser at runtime

# Production Server URL
# In development: empty (uses Vite proxy)
# In production: https://your-railway-app.railway.app (full URL to server)
VITE_SERVER_URL=

# API Base URL (optional, for custom API routing)
# Usually handled by axios with /api proxy
VITE_API_URL=/api

# ════════════════════════════════════════════════════════════════
# Development Notes:
# ════════════════════════════════════════════════════════════════
# • Vite automatically proxies /api to http://localhost:5000
# • Socket.io also proxies through /socket.io
# • No need to set VITE_SERVER_URL in development
#
# For Production (deployed on Vercel/Railway):
# • Set VITE_SERVER_URL to your Railway backend URL
# • Client socket.js will use this to connect from production
# ════════════════════════════════════════════════════════════════
